{
  "expo": {
    "name": "Height Measurement",
    "slug": "heightmeasurement",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "heightmeasurement",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.heightmeasurement"
    },
    "android": {
      "package": "com.example.heightmeasurement",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Height Measurement to use your camera to capture a measurement photo."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Height Measurement to use camera for live measurement guidance."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e2b0c757-eaa5-4a76-976b-63f3643191e6"
      }
    }
  }
}
